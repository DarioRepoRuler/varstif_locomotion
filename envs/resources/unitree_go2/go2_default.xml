    <exclude body1="RL_calf" body2="RR_thigh"/>
    <exclude body1="RL_calf" body2="RL_thigh"/>

    <!-- Exclude collisions between calfs and feet -->
    <exclude body1="FR_calf" body2="FR_foot"/>
    <exclude body1="FR_calf" body2="FL_foot"/>
    <exclude body1="FR_calf" body2="RR_foot"/>
    <exclude body1="FR_calf" body2="RL_foot"/>

    <exclude body1="FL_calf" body2="FR_foot"/>
    <exclude body1="FL_calf" body2="FL_foot"/>
    <exclude body1="FL_calf" body2="RR_foot"/>
    <exclude body1="FL_calf" body2="RL_foot"/>

    <exclude body1="RR_calf" body2="FR_foot"/>
    <exclude body1="RR_calf" body2="FL_foot"/>
    <exclude body1="RR_calf" body2="RR_foot"/>
    <exclude body1="RR_calf" body2="RL_foot"/>

    <exclude body1="RL_calf" body2="FR_foot"/>

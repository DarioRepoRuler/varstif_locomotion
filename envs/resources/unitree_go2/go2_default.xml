    <exclude body1="RR_hip" body2="RR_calf"/>
    <exclude body1="RR_hip" body2="RL_calf"/>

    <exclude body1="RL_hip" body2="FR_calf"/>
    <exclude body1="RL_hip" body2="FL_calf"/>
    <exclude body1="RL_hip" body2="RR_calf"/>
    <exclude body1="RL_hip" body2="RL_calf"/>

    <!-- Exclude collisions between hips and feet -->
    <exclude body1="FR_hip" body2="FR_foot"/>
    <exclude body1="FR_hip" body2="FL_foot"/>
    <exclude body1="FR_hip" body2="RR_foot"/>
    <exclude body1="FR_hip" body2="RL_foot"/>

    <exclude body1="FL_hip" body2="FR_foot"/>

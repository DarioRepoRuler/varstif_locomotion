    <exclude body1="RR_hip" body2="RR_foot"/>
    <exclude body1="RR_hip" body2="RL_foot"/>

    <exclude body1="RL_hip" body2="FR_foot"/>
    <exclude body1="RL_hip" body2="FL_foot"/>
    <exclude body1="RL_hip" body2="RR_foot"/>
    <exclude body1="RL_hip" body2="RL_foot"/>

    <!-- Exclude collisions between thighs and feet -->
    <exclude body1="FR_thigh" body2="FR_foot"/>
    <exclude body1="FR_thigh" body2="FL_foot"/>
    <exclude body1="FR_thigh" body2="RR_foot"/>
    <exclude body1="FR_thigh" body2="RL_foot"/>

    <exclude body1="FL_thigh" body2="FR_foot"/>

<mujoco model="go2">
  <compiler angle="radian" meshdir="assets" autolimits="false"/>

  <option timestep="0.005" impratio="5"/>
  <option cone="pyramidal" impratio="100" iterations="1" ls_iterations="5">
    <flag eulerdamp="disable"/>
  </option>

  <contact>
    <!-- Exclude collisions between all body parts -->

    <!-- Exclude trunk with thigh, hip and foot -->
    <exclude body1="FR_hip" body2="trunk"/>
    <exclude body1="FL_hip" body2="trunk"/>
    <exclude body1="RR_hip" body2="trunk"/>
    <exclude body1="RL_hip" body2="trunk"/>

    <exclude body1="FR_thigh" body2="trunk"/>
    <exclude body1="FL_thigh" body2="trunk"/>
    <exclude body1="RR_thigh" body2="trunk"/>
    <exclude body1="RL_thigh" body2="trunk"/>

    <exclude body1="FR_calf" body2="trunk"/>
    <exclude body1="FL_calf" body2="trunk"/>
    <exclude body1="RR_calf" body2="trunk"/>
    <exclude body1="RL_calf" body2="trunk"/>

    <exclude body1="FR_foot" body2="trunk"/>
    <exclude body1="FL_foot" body2="trunk"/>
    <exclude body1="RR_foot" body2="trunk"/>
    <exclude body1="RL_foot" body2="trunk"/>

    <!-- Exclude collisions between hips and thights -->
    <exclude body1="FR_hip" body2="FR_thigh"/>
    <exclude body1="FR_hip" body2="FL_thigh"/>
    <exclude body1="FR_hip" body2="RR_thigh"/>
    <exclude body1="FR_hip" body2="RL_thigh"/>

    <exclude body1="FL_hip" body2="FR_thigh"/>
    <exclude body1="FL_hip" body2="FL_thigh"/>
    <exclude body1="FL_hip" body2="RR_thigh"/>
    <exclude body1="FL_hip" body2="RL_thigh"/>

    <exclude body1="RR_hip" body2="FR_thigh"/>
    <exclude body1="RR_hip" body2="FL_thigh"/>
    <exclude body1="RR_hip" body2="RR_thigh"/>
    <exclude body1="RR_hip" body2="RL_thigh"/>

    <exclude body1="RL_hip" body2="FR_thigh"/>
    <exclude body1="RL_hip" body2="FL_thigh"/>
    <exclude body1="RL_hip" body2="RR_thigh"/>
    <exclude body1="RL_hip" body2="RL_thigh"/>

    <!-- Exclude collisions between hips and calfs -->
    <exclude body1="FR_hip" body2="FR_calf"/>
    <exclude body1="FR_hip" body2="FL_calf"/>
    <exclude body1="FR_hip" body2="RR_calf"/>
    <exclude body1="FR_hip" body2="RL_calf"/>

    <exclude body1="FL_hip" body2="FR_calf"/>
